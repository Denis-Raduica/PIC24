END DISPLAY
BEGIN DISPLAY 72 48 PIN OVF ATTR PinName
    FONT 24 "Arial"
END DISPLAY
BEGIN DISPLAY 72 96 PIN CF ATTR PinName
    FONT 24 "Arial"
END DISPLAY
BEGIN DISPLAY 76 224 PIN Branch(2:0) ATTR PinName
    FONT 24 "Arial"
END DISPLAY
BEGIN DISPLAY 176 64 PIN Offset(15:0) ATTR PinName
    FONT 24 "Arial"
END DISPLAY
BEGIN DISPLAY 216 160 PIN PC(22:0) ATTR PinName
    FONT 24 "Arial"
END DISPLAY
BEGIN DISPLAY 232 -112 PIN New_PC(22:0) ATTR PinName
