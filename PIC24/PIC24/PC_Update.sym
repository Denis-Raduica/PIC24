VERSION 5
BEGIN SYMBOL PC_Update
SYMBOLTYPE BLOCK
TIMESTAMP 2025 1 3 13 21 39
SYMPIN 0 -48 Input NF
SYMPIN 0 0 Input ZF
SYMPIN 0 48 Input OVF
SYMPIN 0 96 Input CF
SYMPIN 0 224 Input Branch(2:0)
SYMPIN 384 64 Input Offset(15:0)
SYMPIN 384 160 Input PC(22:0)
SYMPIN 0 -112 Output New_PC(22:0)
BEGIN DISPLAY 200 -140 ATTR SymbolName
    ALIGNMENT BCENTER
    FONT 56 "Arial"
END DISPLAY
BEGIN DISPLAY 72 -48 PIN NF ATTR PinName
    FONT 24 "Arial"
END DISPLAY
BEGIN DISPLAY 72 0 PIN ZF ATTR PinName
